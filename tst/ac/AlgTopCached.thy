        unfolding is_topology_on_def by (by100 blast)
      from this[of "{V, W}"] hUVW(12,13) have "\<Union>{V, W} \<in> top1_S2_topology" by (by100 blast)
      moreover have "\<Union>{V, W} = V \<union> W" by (by100 blast)

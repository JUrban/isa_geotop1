      \<comment> \<open>Rk \<subseteq> W12a or W12b. WLOG say Rk \<subseteq> W12b (we'll identify the side).\<close>
      have hRk_in_W12: "Rk \<subseteq> W12a \<or> Rk \<subseteq> W12b"

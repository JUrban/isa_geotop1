            \<comment> \<open>Tail equality + group assoc + merge = foldr equality.\<close>
            have htail_eq_V: "\<And>j. 2 \<le> j \<Longrightarrow> j < n \<Longrightarrow> piece_V j sub = piece_V (j - 1) sub'"

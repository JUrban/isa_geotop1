                  then obtain T where hT: "open T" and hTeq: "T \<inter> I_set = \<phi>c -` W \<inter> I_set"
                    by (by100 blast)
                  have "{s \<in> I_set. \<phi>c s \<in> V'} = {s \<in> I_set. \<phi>c s \<in> W}"

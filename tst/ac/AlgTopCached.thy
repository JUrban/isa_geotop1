        hence "V \<subseteq> U" using \<open>P1 \<subseteq> U\<close> by (by100 blast)
        hence "V \<inter> U \<noteq> {}" using hUVW(2) by (by100 blast)
        thus False using hUVW(4) by (by100 blast)

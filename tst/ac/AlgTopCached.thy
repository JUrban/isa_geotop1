    hence "top1_path_component_of_on (top1_S2 - (?A \<union> ?B))
        (subspace_topology top1_S2 top1_S2_topology (top1_S2 - (?A \<union> ?B))) x_P =
        top1_component_of_on (top1_S2 - (?A \<union> ?B))
        (subspace_topology top1_S2 top1_S2_topology (top1_S2 - (?A \<union> ?B))) x_P"

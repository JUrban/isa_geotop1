              moreover have "x \<notin> ?Arc2 - {a1,a2}" using hx_nW13b hArc2_b by (by100 blast)
              moreover have "x \<notin> Ri_e"
              proof -
                have "Ri_e \<subseteq> W13b"
                proof -

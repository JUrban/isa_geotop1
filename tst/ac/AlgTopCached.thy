              next
                fix k assume hk: "k < length (map (\<lambda>i. \<sigma> (piece_V i sub')) [1..<n-1])"
                hence hk2: "k < n - Suc 1" using hn2 by (by100 simp)
                show "map (\<lambda>i. \<sigma> (piece_V i sub')) [1..<n-1] ! k =
                    map (\<lambda>i. \<sigma> (piece_V (Suc i) sub')) [0..<n - Suc 1] ! k"

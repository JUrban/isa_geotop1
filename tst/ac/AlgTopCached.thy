    \<comment> \<open>(e13\_pa3 \<union> e23) \<inter> e24\_a2q = {a2}.\<close>
    have hint2_loc: "(e13_pa3 \<union> e23) \<inter> e24_a2q = {a2}"
    proof (rule set_eqI, rule iffI)

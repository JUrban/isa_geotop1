      have hinj: "inj_on h top1_unit_interval"
        using hh unfolding top1_homeomorphism_on_def bij_betw_def by (by100 blast)
      have "(0::real) \<in> top1_unit_interval" "(1::real) \<in> top1_unit_interval"

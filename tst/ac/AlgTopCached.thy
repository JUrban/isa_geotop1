          qed
          have hR3_open_23: "R3 \<in> ?T23"
          proof -
            have "R3 = (R2 \<union> R3) \<inter> R3" by (by100 blast)
            thus ?thesis unfolding subspace_topology_def using hR(13) by (by100 blast)

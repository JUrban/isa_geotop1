  \<comment> \<open>D1 endpoints: step 1: endpoints(e13\_pa3 \<union> e23) = {p, a2}.\<close>
  have hD1_ep_step1: "top1_arc_endpoints_on (e13_pa3 \<union> e23)
      (subspace_topology top1_S2 top1_S2_topology (e13_pa3 \<union> e23)) = {p, a2}"

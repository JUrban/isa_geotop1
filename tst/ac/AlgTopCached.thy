              hence "x \<in> (top1_S2 - ?theta) \<union> (?Arc2 - {a1,a2})" using hS2J13_eq by (by100 blast)
              hence "x \<in> R1\<union>R2\<union>R3\<union>(?Arc2-{a1,a2})" using hR(7) by (by100 blast)

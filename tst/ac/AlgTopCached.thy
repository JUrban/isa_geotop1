      moreover have "a3 \<in> e23" using assms(17) unfolding top1_arc_endpoints_on_def by (by100 blast)
      ultimately show "x \<in> e13_pa3 \<inter> e23" using \<open>x \<in> {a3}\<close> by (by100 blast)

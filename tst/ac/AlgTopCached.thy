            \<comment> \<open>Unfold foldr for LHS and RHS, apply merge.\<close>
            have hLHS_V: "foldr_\<sigma> g n sub = foldr mulH (map (\<lambda>i. \<sigma> (piece_V i sub)) [0..<n]) eH"

                subspace_topology (top1_S2 - (?B \<union> ?C))
                    (subspace_topology top1_S2 top1_S2_topology (top1_S2 - (?B \<union> ?C))) V"
              using subspace_topology_trans[of V "top1_S2 - (?B \<union> ?C)" top1_S2 top1_S2_topology]
                  hV_sub_BC by (by100 simp)

    have he13_a1p_sub_loc: "e13_a1p \<subseteq> top1_S2" using he13_sub he13_split(1) by (by100 blast)
    have hpa3_eps_loc: "top1_arc_endpoints_on e13_pa3
        (subspace_topology top1_S2 top1_S2_topology e13_pa3) = {p, a3}"

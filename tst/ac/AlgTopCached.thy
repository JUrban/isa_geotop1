      using arc_split_endpoints(2)[OF hS2_strict hS2_haus he13_sub he13_arc
          he13_split(1) he13_split(2) he13_split(3) he13_split(4)
          he13_split(5) he13_split(6) he13_split(7) he13_split(8)

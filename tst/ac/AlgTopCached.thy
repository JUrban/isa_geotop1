              fix us :: "('s \<times> bool) list"
              assume hus: "\<forall>i<length us. fst(us!i) \<in> S1"
              show "top1_group_word_product mul1 e1 invg1 (map (\<lambda>(s,b). (\<iota>1 s, b)) us) \<in> G1"

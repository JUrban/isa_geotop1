              hence "W2 \<subseteq> V \<inter> U" using hW2Q \<open>Q \<subseteq> V\<close> by (by100 blast)
              hence "W2 = {}" using hUV_loc(5) by (by100 blast)
              thus ?thesis using hW(2) by (by100 blast)

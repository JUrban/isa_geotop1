        hence "Rk \<subseteq> top1_S2 - ?theta" using hR(7) by (by100 blast)
        thus ?thesis by (by100 blast)
      qed
      have hRk_sub_J13: "Rk \<subseteq> top1_S2 - (e12 \<union> ?Arc3)"
      proof -
        have "Rk \<subseteq> top1_S2 - ?theta" using hRk(1) hR(7) by (by100 blast)

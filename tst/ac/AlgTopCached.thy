      \<comment> \<open>Step 3: Rk \<subseteq> S2-J12 and S2-J13. Rk connected \<Rightarrow> in one component of each.\<close>
      have hRk_sub_J12: "Rk \<subseteq> top1_S2 - (e12 \<union> ?Arc2)"
